def build_copilot_usage_endpoint(
    *, username: str | None = None, org: str | None = None
) -> str:
    normalized_username = username.strip() if isinstance(username, str) else ""
    normalized_org = org.strip() if isinstance(org, str) else ""
    if normalized_username and normalized_org:
        raise ValueError("Use either --username or --org, not both.")
    if normalized_org:
        return f"/organizations/{normalized_org}/settings/billing/premium_request/usage"
    if normalized_username:
        return f"/users/{normalized_username}/settings/billing/premium_request/usage"
    raise ValueError("username or org is required")


def build_copilot_usage_gh_args(
    endpoint: str,
    *,
    year: int | None = None,
    month: int | None = None,
    day: int | None = None,
    model: str | None = None,
    product: str | None = None,
) -> list[str]:
    args = [
        "api",
        endpoint,
        "--method",
        "GET",
        "-H",
        "Accept: application/vnd.github+json",
        "-H",
        f"X-GitHub-Api-Version: {GITHUB_REST_API_VERSION}",
    ]
    if year is not None:
        args.extend(["-F", f"year={year}"])
    if month is not None:
        args.extend(["-F", f"month={month}"])
    if day is not None:
        args.extend(["-F", f"day={day}"])
    if model:
        args.extend(["-F", f"model={model}"])
    if product:
        args.extend(["-F", f"product={product}"])
    return args


def _run_gh_command(
    args: list[str], *, timeout: int = 30
) -> subprocess.CompletedProcess[str]:
    binary = shutil.which("gh")
    if not binary:
        raise ValueError("gh not found on PATH")
    try:
        return subprocess.run(
            [binary, *args],
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except OSError as exc:
        raise ValueError(f"failed to execute gh: {exc}") from exc


def _gh_error_message(result: subprocess.CompletedProcess[str]) -> str:
    return (result.stderr or result.stdout or "unknown gh error").strip()


def _gh_json_output(
    args: list[str], *, timeout: int = 30
) -> dict[str, Any]:
    result = _run_gh_command(args, timeout=timeout)
    if result.returncode != 0:
        raise ValueError(f"gh api failed: {_gh_error_message(result)}")

    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise ValueError("gh api returned invalid JSON") from exc
    if not isinstance(payload, dict):
        raise ValueError("gh api returned an unexpected response shape")
    return payload


def resolve_gh_authenticated_username() -> str:
    result = _run_gh_command(["api", "/user", "--jq", ".login"], timeout=15)
    if result.returncode != 0:
        raise ValueError(f"Failed to resolve GitHub username: {_gh_error_message(result)}")

    username = result.stdout.strip()
    if not username:
        raise ValueError("Failed to resolve GitHub username from gh auth context")
    return username


def fetch_copilot_usage_report(
    *,
    username: str | None = None,
    org: str | None = None,
    year: int | None = None,
    month: int | None = None,
    day: int | None = None,
    model: str | None = None,
    product: str | None = None,
) -> dict[str, Any]:
    resolved_username = username.strip() if isinstance(username, str) else ""
    resolved_org = org.strip() if isinstance(org, str) else ""
    if not resolved_username and not resolved_org:
        resolved_username = resolve_gh_authenticated_username()

    endpoint = build_copilot_usage_endpoint(
        username=resolved_username or None,
        org=resolved_org or None,
    )
    args = build_copilot_usage_gh_args(
        endpoint,
        year=year,
        month=month,
        day=day,
        model=model.strip() if isinstance(model, str) and model.strip() else None,
        product=(
            product.strip() if isinstance(product, str) and product.strip() else None
        ),
    )
    return _gh_json_output(args)


def _coerce_usage_float(value: Any) -> float:
    if isinstance(value, bool):
        return float(int(value))
    if isinstance(value, (int, float)):
        return float(value)
    return 0.0


def summarize_copilot_usage_report(report: dict[str, Any]) -> dict[str, float | int]:
    raw_items = report.get("usageItems")
    items = raw_items if isinstance(raw_items, list) else []
    totals: dict[str, float | int] = {
        "gross_quantity": 0,
        "discount_quantity": 0,
        "net_quantity": 0,
        "gross_amount": 0.0,
        "discount_amount": 0.0,
        "net_amount": 0.0,
    }
    for item in items:
        if not isinstance(item, dict):
            continue
        totals["gross_quantity"] += _coerce_usage_int(item.get("grossQuantity"))
        totals["discount_quantity"] += _coerce_usage_int(
            item.get("discountQuantity")
        )
        totals["net_quantity"] += _coerce_usage_int(item.get("netQuantity"))
        totals["gross_amount"] += _coerce_usage_float(item.get("grossAmount"))
        totals["discount_amount"] += _coerce_usage_float(item.get("discountAmount"))
        totals["net_amount"] += _coerce_usage_float(item.get("netAmount"))
    return totals


def _format_number(value: Any) -> str:
    if isinstance(value, bool):
        value = int(value)
    if isinstance(value, int):
        return _format_int(value)
    if isinstance(value, float):
        if value.is_integer():
            return _format_int(int(value))
        return f"{value:,.2f}"
    return ""


def _format_currency(value: Any) -> str:
    amount = _coerce_usage_float(value)
    return f"${amount:,.2f}"


def format_copilot_usage_time_period(value: Any) -> str:
    if not isinstance(value, dict):
        return ""
    year = value.get("year")
    month = value.get("month")
    day = value.get("day")
    if isinstance(year, (int, float)) and isinstance(month, (int, float)):
        if isinstance(day, (int, float)):
            return f"{int(year):04d}-{int(month):02d}-{int(day):02d}"
        return f"{int(year):04d}-{int(month):02d}"
    if isinstance(year, (int, float)):
        return str(int(year))
    return ""


def render_copilot_usage_report(report: dict[str, Any]) -> None:
    console = Console()
    raw_items = report.get("usageItems")
    items = [item for item in raw_items if isinstance(item, dict)] if isinstance(raw_items, list) else []
    summary = summarize_copilot_usage_report(report)

    details = Table(show_header=False, box=None, pad_edge=False)
    details.add_column(style="bold cyan")
    details.add_column()

    user = report.get("user")
    organization = report.get("organization")
    if isinstance(user, str) and user.strip():
        details.add_row("User", user)
    elif isinstance(organization, str) and organization.strip():
        details.add_row("Organization", organization)

    period = format_copilot_usage_time_period(report.get("timePeriod"))
    if period:
        details.add_row("Period", period)

    details.add_row("Usage items", _format_int(len(items)))
    details.add_row("Net requests", _format_number(summary["net_quantity"]))
    details.add_row("Net billed", _format_currency(summary["net_amount"]))
    if summary["discount_quantity"] or summary["discount_amount"]:
        details.add_row(
            "Discounts",
            f"{_format_number(summary['discount_quantity'])} / {_format_currency(summary['discount_amount'])}",
        )
    console.print(details)

    if not items:
        console.print("No Copilot premium request usage returned.")
        return

    table = Table(show_header=True, header_style="bold cyan")
    table.add_column("Model", style="green")
    table.add_column("Unit")
    table.add_column("Gross reqs", justify="right")
    table.add_column("Discount reqs", justify="right")
    table.add_column("Net reqs", justify="right")
    table.add_column("Unit price", justify="right")
    table.add_column("Net billed", justify="right")

    for item in items:
        table.add_row(
            str(item.get("model") or ""),
            str(item.get("unitType") or ""),
            _format_number(item.get("grossQuantity")),
            _format_number(item.get("discountQuantity")),
            _format_number(item.get("netQuantity")),
            _format_currency(item.get("pricePerUnit")),
            _format_currency(item.get("netAmount")),
        )

    table.add_section()
    table.add_row(
        "Total",
        "",
        _format_number(summary["gross_quantity"]),
        _format_number(summary["discount_quantity"]),
        _format_number(summary["net_quantity"]),
        "",
        _format_currency(summary["net_amount"]),
    )
    console.print(table)


def create_client(
    provider: str, api_key: str | None = None, base_url: str | None = None
) -> AsyncOpenAI:
    normalized = provider.strip().lower()
    if normalized == "copilot":
        return create_openai_copilot_client()
    if normalized == "openai":
        resolved_api_key = (
            api_key or os.getenv("OPENAI_API_KEY") or os.getenv("NANO_AGENT_API_KEY")
        )
        if not resolved_api_key:
            raise ValueError(
                "OpenAI API key not found. Set OPENAI_API_KEY or pass --api-key."
            )
        resolved_base_url = (
            base_url or os.getenv("OPENAI_BASE_URL") or os.getenv("NANO_AGENT_BASE_URL")
        )
        return create_direct_openai_client(resolved_api_key, resolved_base_url)
    raise ValueError(f"unsupported provider: {provider}")


def generate_device_flow() -> dict[str, Any]:
    response = httpx.post(
        COPILOT_DEVICE_URL,
        data={
            "client_id": COPILOT_CLIENT_ID,
            "scope": " ".join(COPILOT_SCOPES),
        },
        headers={
            "Accept": "application/json",
            "User-Agent": "nano-agent",
        },
        timeout=30,
    )
    response.raise_for_status()
    return response.json()


def poll_for_token(device_code: str, interval: int, expires_in: int) -> dict[str, Any]:
    timeout_at = time.time() + expires_in
    current_interval = interval
    while time.time() < timeout_at:
        time.sleep(current_interval)
        response = httpx.post(
            COPILOT_TOKEN_URL,
            data={
                "client_id": COPILOT_CLIENT_ID,
                "device_code": device_code,
                "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
            },
            headers={"Accept": "application/json"},
            timeout=30,
        )
        response.raise_for_status()
        data = response.json()
        error = data.get("error")
        if not error:
            return data
        if error == "authorization_pending":
            continue
        if error == "slow_down":
            current_interval += 5
            continue
        raise CopilotAuthError(
            f"Authentication failed: {error} - {data.get('error_description', '')}"
        )
    raise CopilotAuthError("Authentication timed out")


def exchange_for_copilot_token(access_token: str) -> dict[str, Any]:
    response = httpx.get(
        COPILOT_EXCHANGE_URL,
        headers=copilot_token_exchange_headers(access_token),
        timeout=30,
    )
    response.raise_for_status()
    return response.json()



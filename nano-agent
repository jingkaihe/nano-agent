            if isinstance(value.get("last_model"), str)
            else None,
        )

    def to_dict(self) -> dict[str, Any]:
        return {
            "request_count": self.request_count,
            "input_tokens": self.input_tokens,
            "output_tokens": self.output_tokens,
            "total_tokens": self.total_tokens,

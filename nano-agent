        _assert_equal(refreshed["copilot_expires_at"], "2099-01-01T00:00:00Z")
        _assert_equal(len(saved_creds), 1)
        _assert_equal(saved_creds[0]["copilot_token"], "fresh-copilot-token")
    finally:
